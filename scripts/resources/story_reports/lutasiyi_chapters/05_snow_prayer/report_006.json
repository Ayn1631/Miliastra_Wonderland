                                {
                                    "param_type": "String",
                                    "value": "57"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "“——风啊，请听一听凡人的悲歌。我们无意冒犯神明，"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
                                    "value": [
                                        "55"
