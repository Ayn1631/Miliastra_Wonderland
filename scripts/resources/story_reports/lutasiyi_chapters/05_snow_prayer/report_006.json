                                    "param_type": "String",
                                    "value": "57"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "请回应我们吧……哪怕只有一缕，温和的风……”"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
                                    "value": [
                                        "58"
