                                {
                                    "param_type": "String",
                                    "value": "57"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "“如果漫天的风雪只有毁灭，那这天地生出微风的意义又在哪里？"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
