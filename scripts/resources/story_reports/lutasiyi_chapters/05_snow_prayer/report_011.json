                                {
                                    "param_type": "String",
                                    "value": "4"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "在未来，你们的后代，将生生世世践行‘永护蒙德’的誓言，"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
