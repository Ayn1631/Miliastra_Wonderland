                            "value": [
                                {
                                    "param_type": "String",
                                    "value": "6"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "感受到一种温热、柔软、宛如猫咪爪垫般的细腻触感。"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
                                    "value": [
                                        "104"
                                    ]
                                }
                            ]
                        }
                    },
                    {
                        "param_type": "Struct",
                        "value": {
                            "structId": "1077936129",
                            "type": "Struct",
                            "value": [
                                {
                                    "param_type": "String",
                                    "value": "4"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "“是的，年轻的古恩希尔德。”我轻声微笑着，"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
                                    "value": [
                                        "105"
                                    ]
                                }
                            ]
                        }
                    },
                    {
                        "param_type": "Struct",
                        "value": {
                            "structId": "1077936129",
                            "type": "Struct",
                            "value": [
                                {
                                    "param_type": "String",
                                    "value": "4"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "语气里充满了无法言喻的敬意与温柔，“我在三千年后的蒙德，注视着你们。"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
                                    "value": [
                                        "106"
                                    ]
                                }
                            ]
                        }
                    },
                    {
                        "param_type": "Struct",
                        "value": {
                            "structId": "1077936129",
