                                {
                                    "param_type": "String",
                                    "value": "4"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "在我的时代，暴风雪早已平息，高塔也已化为尘土。"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
                                    "value": [
                                        "107"
                                    ]
                                }
                            ]
