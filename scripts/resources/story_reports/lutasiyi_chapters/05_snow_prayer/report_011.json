                                {
                                    "param_type": "String",
                                    "value": "6"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "一遍又一遍地摩挲着石板上流转的星光。那一瞬间，我甚至能通过石板，"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
                                    "value": [
                                        "103"
                                    ]
                                }
                            ]
                        }
                    },
                    {
                        "param_type": "Struct",
