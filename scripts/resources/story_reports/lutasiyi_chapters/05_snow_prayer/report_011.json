                        "value": {
                            "structId": "1077936129",
                            "type": "Struct",
                            "value": [
                                {
                                    "param_type": "String",
                                    "value": "6"
                                },
                                {
                                    "param_type": "StringList",
                                    "value": [
                                        "而在石板的表面，那一缕微小无形的风之精灵，正用它那青色温暖的身体，"
                                    ]
                                },
                                {
                                    "param_type": "Int32List",
                                    "value": [
                                        "102"
                                    ]
                                }
                            ]
                        }
                    },
                    {
