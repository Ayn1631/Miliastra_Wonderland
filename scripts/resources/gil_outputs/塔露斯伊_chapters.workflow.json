            },
            "Story_List": [
              {
                "status": "6",
                "str": [
                  "石板那头传来了卢卡极其简短、却极其坚决的回应："
                ],
                "next": [
                  31
                ]
              },
              {
                "status": "7",
                "str": [
                  "0"
                ],
                "next": [
                  10113
                ]
              },
              {
                "status": "5",
                "str": [
                  "“好……长官，我相信你。我这就带上几名相熟的年轻猎手，"
                ],
                "next": [
                  33
                ]
              },
              {
                "status": "5",
                "str": [
                  "往正北走！”"
                ],
                "next": [
                  34
                ]
              },
              {
                "status": "8",
