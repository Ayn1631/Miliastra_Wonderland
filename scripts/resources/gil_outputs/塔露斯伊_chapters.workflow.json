          "value": {
            "__struct_types__": {
              "Story_List": "StoryNode"
            },
            "Story_List": [
              {
                "status": "6",
                "str": [
                  "但那一双清澈如晨星的眼眸中，却没有丝毫的屈服。"
                ],
                "next": [
                  51
                ]
              },
              {
                "status": "6",
                "str": [
                  "她，正是古恩希尔德家族的族长女儿。"
                ],
                "next": [
                  52
                ]
              },
              {
                "status": "6",
                "str": [
                  "此时，她正高高举起一个粗糙的、刻满岁月痕迹的古旧石杯。"
                ],
                "next": [
                  53
                ]
              },
              {
                "status": "6",
                "str": [
                  "面对那仿佛要吞噬一切的极寒冰风，她用近乎沙哑却无比坚定的声音，领着身后的族人们高声呼喊："
                ],
                "next": [
                  54
                ]
              },
              {
                "status": "57",
                "str": [
                  "“——风啊，请听一听凡人的悲歌。我们无意冒犯神明，"
                ],
                "next": [
                  55
                ]
              },
              {
                "status": "57",
                "str": [
                  "亦不求登临天之高座，我们只是想要活下去……想要在这片冰原上，为我们的孩子寻找一块没有狂暴风雪遮蔽的土地。”"
                ],
                "next": [
                  56
                ]
              },
              {
                "status": "57",
                "str": [
                  "“如果漫天的风雪只有毁灭，那这天地生出微风的意义又在哪里？"
                ],
                "next": [
                  57
                ]
              },
              {
                "status": "57",
                "str": [
                  "请回应我们吧……哪怕只有一缕，温和的风……”"
                ],
                "next": [
                  58
                ]
              },
              {
                "status": "6",
                "str": [
                  "随着她的歌声，崖壁下所有冻僵的凡人都双手合十，将他们最后的求生执念，"
                ],
                "next": [
                  59
                ]
              },
              {
                "status": "6",
                "str": [
                  "汇聚在这风雪中的低吟中。"
                ],
                "next": [
                  60
                ]
              }
            ]
          },
          "source_report": "C:\\Users\\20753\\Desktop\\gia逆向\\scripts\\resources\\story_reports\\lutasiyi_chapters\\05_snow_prayer\\report_006.json"
